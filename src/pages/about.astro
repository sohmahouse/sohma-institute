    }
  }

  /* ═══════════ MAIN LOOP ═══════════ */
  var tOffset = 0

  function tick() {
    if (!visible) { animId = 0; return }
    animId = requestAnimationFrame(tick)
    time += 0.016
    tOffset = time * 0.00004 * TAU

    ctx.clearRect(0, 0, W, H)

    // Detect hover with current offset
    if (mouseX > -9000) detectHover(mouseX, mouseY, tOffset)

    // Update spark color
    var col = getColors()
    _sparkRgb = col.spark

    drawTriquetraPath(tOffset)
    drawNodeHalos(tOffset)
    drawFlowParticles(tOffset)
    drawOrbitals(tOffset)
    drawSparks()
  }

  /* ── Visibility gating ── */
  var observer = new IntersectionObserver(function(entries) {
    for (var i = 0; i < entries.length; i++) {
      if (entries[i].isIntersecting) { visible = true; if (!animId) tick() }
      else { visible = false }
    }
  }, { threshold: 0.15 })
  observer.observe(wrap)

  /* ── Mouse / Touch ── */
  function onEcoMouseMove(e) {
    var rect = canvas.getBoundingClientRect()
    mouseX = (e.clientX - rect.left) * (W / rect.width)
    mouseY = (e.clientY - rect.top) * (H / rect.height)
  }
  function onEcoMouseLeave() { mouseX = -9999; mouseY = -9999; hoveredNode = -1 }
  function onEcoTouchMove(e) {
    if (e.touches.length > 0) {
      var rect = canvas.getBoundingClientRect()
      mouseX = (e.touches[0].clientX - rect.left) * (W / rect.width)
      mouseY = (e.touches[0].clientY - rect.top) * (H / rect.height)
    }
  }
  function onEcoTouchEnd() { mouseX = -9999; mouseY = -9999; hoveredNode = -1 }
  wrap.addEventListener('mousemove', onEcoMouseMove)
  wrap.addEventListener('mouseleave', onEcoMouseLeave)
  wrap.addEventListener('touchmove', onEcoTouchMove, { passive: true })
  wrap.addEventListener('touchend', onEcoTouchEnd)

  /* ── Theme observer ── */
  var themeObs = new MutationObserver(function() { if (visible && !animId) tick() })
  themeObs.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] })

  /* ── Cleanup ── */
  window.__ecoCleanup = function() {
    if (animId) cancelAnimationFrame(animId)
    animId = 0; visible = false
    observer.disconnect()
    themeObs.disconnect()
    window.removeEventListener('resize', debouncedResize)
    wrap.removeEventListener('mousemove', onEcoMouseMove)
    wrap.removeEventListener('mouseleave', onEcoMouseLeave)
    wrap.removeEventListener('touchmove', onEcoTouchMove)
    wrap.removeEventListener('touchend', onEcoTouchEnd)
  }
}
__ecoTriquetraInit()
</script>

<script>
/* ── Scroll-based band activation ── */
function initAboutBandScroll() {
  const bands = document.querySelectorAll('.about-band')
  if (!bands.length) return

  function update() {
    const midY = window.innerHeight * 0.5
    let closest = -1
    let closestDist = Infinity

    bands.forEach((band, i) => {
      const rect = band.getBoundingClientRect()
      const center = rect.top + rect.height * 0.5
      const dist = Math.abs(center - midY)
      if (dist < closestDist) {
        closestDist = dist
        closest = i
      }
    })

    bands.forEach((band, i) => {
      band.classList.toggle('active', i === closest)
    })
  }

  window.addEventListener('scroll', update, { passive: true })
  window.addEventListener('resize', update, { passive: true })
  update()
}

initAboutBandScroll()
document.addEventListener('astro:page-load', initAboutBandScroll)
</script>
